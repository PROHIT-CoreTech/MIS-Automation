# MIS Portal — Environment Configuration Template
# Copy this file to .env and fill in your values.
# python-dotenv will auto-load it when present.

# ── Database ──────────────────────────────────────────────────
# MIS_DB_PATH=data/mis_portal.db

# ── Tally Prime Connection ─────────────────────────────────────
# TALLY_URL=http://localhost:9000
# TALLY_TIMEOUT=30

# ── Auth / Lockout ─────────────────────────────────────────────
# MAX_LOGIN_ATTEMPTS=3
# LOCKOUT_MINUTES=30

# ── Default Admin (first-time setup) ──────────────────────────
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin@123

# ── Masters File ───────────────────────────────────────────────
# MASTERS_PATH=config/masters/Masters.xlsx
